<?php
/**
 * @var Laminas\View\Renderer\PhpRenderer $this
 */
?>

<section class="error-page">
    <header class="error-hero">
        <div class="error-hero__content">
            <span class="error-hero__eyebrow">Erro interno</span>
            <h1 class="error-hero__title">Ocorreu um erro</h1>
            <p class="error-hero__text">
                <?= $this->escapeHtml($this->message) ?>
            </p>
        </div>

        <div class="error-hero__code">
            <span class="error-hero__code-number">500</span>
            <span class="error-hero__code-label">Error</span>
        </div>
    </header>

    <section class="error-card">
        <h2 class="error-card__title">O que isso significa?</h2>
        <p class="error-card__text">
            A aplicação encontrou uma condição inesperada ao processar a requisição.
            Tente novamente ou revise os detalhes técnicos abaixo, caso o ambiente esteja em modo de depuração.
        </p>
    </section>

    <?php if (!empty($this->display_exceptions)) : ?>
        <?php if (isset($this->exception) && $this->exception instanceof \Throwable) : ?>
            <section class="error-info-card">
                <h2 class="error-section-title">Informações adicionais</h2>

                <div class="error-info-grid">
                    <div class="error-info-item">
                        <span class="error-info-item__label">Classe da exceção</span>
                        <div class="error-info-item__value">
                            <?= $this->escapeHtml(get_class($this->exception)) ?>
                        </div>
                    </div>

                    <div class="error-info-item">
                        <span class="error-info-item__label">Arquivo</span>
                        <div class="error-info-item__value">
                            <?= $this->escapeHtml($this->exception->getFile()) ?>:<?= (int) $this->exception->getLine() ?>
                        </div>
                    </div>
                </div>
            </section>

            <section class="error-debug-card">
                <h2 class="error-section-title">Detalhes técnicos</h2>

                <div class="error-debug-stack">
                    <div class="error-debug-block">
                        <h3 class="error-debug-block__title">Mensagem</h3>
                        <pre><?= $this->escapeHtml($this->exception->getMessage()) ?></pre>
                    </div>

                    <div class="error-debug-block">
                        <h3 class="error-debug-block__title">Stack trace</h3>
                        <pre><?= $this->escapeHtml($this->exception->getTraceAsString()) ?></pre>
                    </div>
                </div>
            </section>

            <?php if ($ex = $this->exception->getPrevious()) : ?>
                <section class="error-debug-card">
                    <h2 class="error-section-title">Exceções anteriores</h2>

                    <ul class="error-prev-list">
                        <?php $icount = 0; ?>
                        <?php while ($ex) : ?>
                            <li class="error-prev-item">
                                <div class="error-debug-stack">
                                    <div class="error-info-item">
                                        <span class="error-info-item__label">Classe da exceção</span>
                                        <div class="error-info-item__value">
                                            <?= $this->escapeHtml(get_class($ex)) ?>
                                        </div>
                                    </div>

                                    <div class="error-debug-block">
                                        <h3 class="error-debug-block__title">Arquivo</h3>
                                        <pre><?= $this->escapeHtml($ex->getFile()) ?>:<?= (int) $ex->getLine() ?></pre>
                                    </div>

                                    <div class="error-debug-block">
                                        <h3 class="error-debug-block__title">Mensagem</h3>
                                        <pre><?= $this->escapeHtml($ex->getMessage()) ?></pre>
                                    </div>

                                    <div class="error-debug-block">
                                        <h3 class="error-debug-block__title">Stack trace</h3>
                                        <pre><?= $this->escapeHtml($ex->getTraceAsString()) ?></pre>
                                    </div>
                                </div>
                            </li>
                            <?php
                            $ex = $ex->getPrevious();
                            if (++$icount >= 50) {
                                echo '<li class="error-empty">Pode haver mais exceções, mas o limite de memória impede exibir todas.</li>';
                                break;
                            }
                            ?>
                        <?php endwhile; ?>
                    </ul>
                </section>
            <?php endif; ?>
        <?php else : ?>
            <section class="error-card">
                <div class="error-empty">Nenhuma exceção disponível.</div>
            </section>
        <?php endif; ?>
    <?php endif; ?>
</section>