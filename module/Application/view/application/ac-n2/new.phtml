<?php
/**
 * @var Laminas\View\Renderer\PhpRenderer $this
 * @var string|null $error
 * @var string $name
 * @var int $acId
 * @var list<Application\Entity\Ac> $acs
 */
?>

<h1>Novo AC N2</h1>

<?php if (!empty($error)): ?>
    <div style="padding:12px; border:1px solid #f3c; background:#fff5f5; border-radius:8px; margin:12px 0;">
        <?= $this->escapeHtml($error) ?>
    </div>
<?php endif; ?>

<?php if (empty($acs)): ?>
    <p>Crie uma AC antes de cadastrar uma AC N2.</p>
    <a href="<?= $this->url('acs/new') ?>">Ir para ACs</a>
<?php else: ?>
    <form method="post" action="<?= $this->url('ac-n2/new') ?>">
        <input type="hidden" name="csrf" value="<?= $this->escapeHtmlAttr($this->csrfToken('acn2_new')) ?>">

        <div style="margin-bottom:12px;">
            <label>AC</label><br>
            <select name="ac_id" required style="padding:8px; width:100%; max-width:420px;">
                <option value="">Selecione...</option>
                <?php foreach ($acs as $ac): ?>
                    <option value="<?= (int) $ac->getId() ?>" <?= ((int)$acId === (int)$ac->getId()) ? 'selected' : '' ?>>
                        #<?= (int) $ac->getId() ?> — <?= $this->escapeHtml($ac->getName()) ?>
                    </option>
                <?php endforeach; ?>
            </select>
        </div>

        <div style="margin-bottom:12px;">
            <label>Nome</label><br>
            <input
                type="text"
                name="name"
                value="<?= $this->escapeHtmlAttr($name) ?>"
                required
                maxlength="150"
                style="padding:8px; width:100%; max-width:420px;"
            >
        </div>

        <div style="display:flex; gap:10px;">
            <button type="submit" style="padding:10px 12px; border:1px solid #ddd; border-radius:8px; cursor:pointer;">Salvar</button>
            <a href="<?= $this->url('ac-n2') ?>" style="padding:10px 12px; border:1px solid #ddd; border-radius:8px; text-decoration:none;">Cancelar</a>
        </div>
    </form>
<?php endif; ?>