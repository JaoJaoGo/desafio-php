                <a href="<?= $this->url('ac-n2/new') ?>" class="crud-btn crud-btn--primary">
                    Ir para AC N2
                </a>
            </div>
        <?php else: ?>
            <form method="post" action="<?= $this->url('ars/new') ?>" class="crud-form">
                <input
                    type="hidden"
                    name="csrf"
                    value="<?= $this->escapeHtmlAttr($this->csrfToken('ar_new')) ?>"
                >

                <div class="crud-form__group">
                    <label class="crud-form__label" for="ac_n2_id">AC N2</label>
                    <select class="crud-form__select" name="ac_n2_id" id="ac_n2_id" required>
                        <option value="">Selecione...</option>
                        <?php foreach ($acN2s as $acN2): ?>
                            <?php $ac = $acN2->getAc(); ?>
                            <option
                                value="<?= (int) $acN2->getId() ?>"
