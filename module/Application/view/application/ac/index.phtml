                        onsubmit="return confirm('Tem certeza que deseja excluir este AC?');"
                    >
                        <input type="hidden" name="csrf" value="<?= $this->escapeHtmlAttr($this->csrfToken('ac_delete_' . $ac->getId())) ?>">
                        <button type="submit">Excluir</button>
                    </form>
