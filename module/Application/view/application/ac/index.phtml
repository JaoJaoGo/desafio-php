<?php endif; ?>

<!-- Modal QRCode (vanilla) -->
<div id="qrModalBackdrop" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.5);"></div>
<div id="qrModal" style="display:none; position:fixed; left:50%; top:50%; transform:translate(-50%,-50%); background:#fff; padding:16px; border-radius:8px; width:360px; max-width:90%;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
        <strong>QR Code</strong>
        <button type="button" onclick="closeQrModal()">X</button>
    </div>

    <div style="text-align:center;">
        <img id="qrImg" src="" alt="QR Code" style="width:300px; height:300px; object-fit:contain;">
        <div style="margin-top:8px;">
            <small id="qrHint"></small>
        </div>
    </div>
</div>

<script>
    function openQrModal(acId){
        var backdrop = document.getElementById('qrModalBackdrop');
        var modal = document.getElementById('qrModal');
        var img = document.getElementById('qrImg');
        var hint = document.getElementById('qrHint');

        // cache-buster para evitar imagem antiga no browser
        img.src = '/acs/' + acId + '/qrcode?_=' + Date.now();
        hint.textContent = 'Conteúdo do QR: /acs/' + acId;

        backdrop.style.display = 'block';
        modal.style.display = 'block';

        backdrop.onclick = closeQrModal;
    }

    function closeQrModal(){
        var backdrop = document.getElementById('qrModalBackdrop');
        var modal = document.getElementById('qrModal');
        var img = document.getElementById('qrImg');

        img.src = '';
        backdrop.style.display = 'none';
        modal.style.display = 'none';
        backdrop.onclick = null;
    }
</script>