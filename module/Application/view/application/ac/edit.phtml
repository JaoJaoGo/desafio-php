<?php /** @var \Laminas\View\Renderer\PhpRenderer $this */ ?>

<h1>Editar AC</h1>

<p>
    <a href="<?= $this->url('acs') ?>">&larr; Voltar</a>
</p>

<?php if (!empty($this->error)): ?>
    <div style="padding:10px; border:1px solid #f00; margin-bottom:10px;">
        <?= $this->escapeHtml($this->error) ?>
    </div>
<?php endif; ?>

<form method="post" action="<?= $this->url('acs/edit', ['id' => $this->ac->getId()]) ?>">
    <input type="hidden" name="csrf" value="<?= $this->escapeHtmlAttr($this->csrfToken('ac_edit_' . $this->ac->getId())) ?>">
    <div style="margin-bottom:10px;">
        <label>Nome</label><br>
        <input
            type="text"
            name="name"
            value="<?= $this->escapeHtmlAttr($this->ac->getName()) ?>"
            required
        >
    </div>

    <button type="submit">Salvar</button>
</form>