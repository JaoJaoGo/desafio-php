    <!-- Modais globais (QRCode + Delete) -->
    <div id="qrModal" class="app-modal" aria-hidden="true">
        <div class="app-modal__dialog app-modal__dialog--qr">
            <div class="app-modal__header">
                <strong class="app-modal__title">QRCode</strong>

                <button
                    type="button"
                    class="app-modal__close"
                    onclick="closeQrModal()"
                    aria-label="Fechar modal de QRCode"
                >
                    ✕
                </button>
            </div>

            <div class="app-modal__body app-modal__body--center">
                <div class="app-qr-preview">
                    <img id="qrImg" alt="QRCode" class="app-qr-preview__image" />
                </div>

                <div class="app-modal__hint">
                    <small id="qrHint"></small>
                </div>
            </div>

            <div class="app-modal__footer">
                <button
                    type="button"
                    class="app-btn app-btn--secondary"
                    onclick="closeQrModal()"
                >
                    Fechar
                </button>
            </div>
        </div>
    </div>

    <div id="deleteModal" class="app-modal" aria-hidden="true">
        <div class="app-modal__dialog">
            <div class="app-modal__header">
                <strong class="app-modal__title">Confirmar exclusão</strong>

                <button
                    type="button"
                    class="app-modal__close"
                    onclick="closeDeleteModal()"
                    aria-label="Fechar modal de exclusão"
                >
                    ✕
                </button>
            </div>

            <div class="app-modal__body">
                <p class="app-modal__text">
                    Tem certeza que deseja excluir este item?
                </p>

                <div class="app-delete-card">
                    <strong id="deleteItemName"></strong>
                </div>

                <p class="app-modal__warning">
                    Esta ação não pode ser desfeita.
                </p>
            </div>

            <div class="app-modal__footer app-modal__footer--actions">
                <button
                    type="button"
                    class="app-btn app-btn--secondary"
                    onclick="closeDeleteModal()"
                >
                    Cancelar
                </button>

                <button
                    type="button"
                    class="app-btn app-btn--danger"
                    onclick="confirmDelete()"
                >
                    Excluir
                </button>
            </div>
        </div>
    </div>

    <script>
    (function(){
        let __deleteForm = null;

        // QR Modal: recebe a URL completa do endpoint que gera o PNG (mais flexível)
        window.openQrModal = function(qrEndpointUrl, hintText){
            const modal = document.getElementById('qrModal');
            const img = document.getElementById('qrImg');
            const hint = document.getElementById('qrHint');

            const sep = qrEndpointUrl.includes('?') ? '&' : '?';
            img.src = qrEndpointUrl + sep + '_=' + Date.now();

            hint.textContent = hintText || '';
            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');

            modal.onclick = function(e){
                if(e.target === modal) window.closeQrModal();
            };
        };

        window.closeQrModal = function(){
            const modal = document.getElementById('qrModal');
            const img = document.getElementById('qrImg');
            const hint = document.getElementById('qrHint');

            img.src = '';
            hint.textContent = '';
            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
            modal.onclick = null;
        };

        window.openDeleteModal = function(btn){
            const form = btn.closest('form[data-delete-form]');
            if(!form) return;

            __deleteForm = form;

            const modal = document.getElementById('deleteModal');
            const nameEl = document.getElementById('deleteItemName');

            const name = form.getAttribute('data-delete-name') || '';
            nameEl.textContent = name !== '' ? name : '(sem nome)';

            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');

            modal.onclick = function(e){
                if(e.target === modal) window.closeDeleteModal();
            };
        };

        window.closeDeleteModal = function(){
            const modal = document.getElementById('deleteModal');
            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
            modal.onclick = null;
            __deleteForm = null;
        };

        window.confirmDelete = function(){
            if(__deleteForm){
                __deleteForm.submit();
            }
        };
    })();
    </script>

    <?= $this->inlineScript() ?>
